# Google Cloud credentials
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# CORS — comma-separated list of allowed origins.
ALLOWED_ORIGINS=http://localhost:3000

# WebSocket API key. Leave empty to disable auth (local dev only).
TTS_API_KEY=

# Redis connection URL
REDIS_URL=redis://localhost:6379

# How long synthesized audio stays cached in Redis (seconds). Default: 24h.
CACHE_TTL_SECONDS=86400

# Max concurrent GCP TTS calls for this worker process.
# Running N workers? Set this to 20/N so total stays within GCP quota.
# e.g. 1 worker=20, 2 workers=10, 4 workers=5
TTS_GLOBAL_CONCURRENCY=20

# Max concurrent TTS calls per WebSocket connection.
TTS_PER_CONN_CONCURRENCY=4

# Max characters allowed per chunk (prevents abuse / runaway GCP billing).
TTS_MAX_CHARS=500

# Daily character budget per client IP (resets at midnight UTC).
TTS_DAILY_CHAR_LIMIT=50000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# BigQuery session analytics (optional — leave GCP_PROJECT unset to disable)
GCP_PROJECT=
BQ_DATASET=tts_pipeline
BQ_TABLE=sessions
BQ_LOCATION=US
